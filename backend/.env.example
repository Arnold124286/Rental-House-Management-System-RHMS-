# Server
PORT=5000
NODE_ENV=production
CLIENT_URL=https://your-rhms-frontend.vercel.app

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rhms_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT Auth
JWT_SECRET=secure_64_char_random_string_here
JWT_EXPIRES_IN=30d

# M-Pesa Daraja (STK Push)
DARAJA_CONSUMER_KEY=your_key_here
DARAJA_CONSUMER_SECRET=your_secret_here
DARAJA_PASSKEY=your_passkey_here
DARAJA_SHORTCODE=174379
DARAJA_CALLBACK_URL=https://your-api.render.com/api/payments/daraja/callback

# Paystack
PAYSTACK_SECRET_KEY=sk_live_xxxx
PAYSTACK_WEBHOOK_URL=https://your-api.render.com/api/payments/paystack/webhook

# Ujumbe SMS
UJUMBE_API_KEY=your_key
UJUMBE_EMAIL=your_email

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="RHMS Support <noreply@rhms.com>"

