# Server
PORT=5000
NODE_ENV=production

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rhms_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT Auth (use a strong 64-char secret in production)
JWT_SECRET=replace_with_a_secure_64_char_random_string
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=https://your-production-domain.com

# M-Pesa Daraja Sandbox
DARAJA_CONSUMER_KEY=your_consumer_key
DARAJA_CONSUMER_SECRET=your_consumer_secret
DARAJA_PASSKEY=your_passkey
DARAJA_SHORTCODE=174379
DARAJA_CALLBACK_URL=https://your-domain.com/api/payments/daraja/callback

# Ujumbe SMS
UJUMBE_API_KEY=your_ujumbe_api_key
UJUMBE_EMAIL=your_ujumbe_email

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="RHMS Admin <your_email@gmail.com>"
