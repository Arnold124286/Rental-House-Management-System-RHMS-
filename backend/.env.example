# Server
PORT=5000
NODE_ENV=production

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rhms_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT Auth (use a strong 64-char secret in production)
JWT_SECRET=replace_with_a_secure_64_char_random_string
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=https://your-production-domain.com
